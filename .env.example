# Coreforge Chatbot — Environment Configuration

# AI Provider Configuration
# Set at least one of these for AI-powered responses.
# Falls back to rule-based responses when no key is set.

# OpenAI (recommended — fastest setup)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# OR Anthropic
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# AI Provider selection (openai or anthropic)
AI_PROVIDER=openai

# Server
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Database path (default: ./data/chatbot.db)
# DB_PATH=/path/to/custom/chatbot.db